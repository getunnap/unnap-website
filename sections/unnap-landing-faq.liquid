        { "type": "faq", "settings": { "question": "How does the competition feature work?", "answer": "<p>You can create or join groups with friends. Your wake-up performance is tracked and scored. Live leaderboards show rankings, and you can compete in 1v1 challenges or group competitions.</p>" } },
        { "type": "faq", "settings": { "question": "What integrations are supported?", "answer": "<p>UNNAP integrates with Strava, Apple Health, Whoop, Oura, Garmin, Philips Hue, and Matter.</p>" } },
