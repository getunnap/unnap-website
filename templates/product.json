                    "padding-inline-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "text_dctg93"
              ]
            },
            "accordion_row_gkdjPw": {
              "type": "_accordion-row",
              "name": "t:names.accordion_dash_row",
              "settings": {
                "heading": "Does UNNAP work offline?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_tXVVxB": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>Yes. All settings are configured in the UNNAP app, but the alarm and NFC functionality work without an internet connection.</p>",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
                    "type_preset": "rte",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
