    "custom_liquid_RGAwPb": {
      "type": "custom-liquid",
      "custom_css": [],
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "{% comment %}\n  UNNAP Review Carousel Section\n  Constantly moving carousel with 12 reviews\n{% endcomment %}\n\n<style>\n  :root {\n    --carousel-speed: 630s;\n  }\n  \n  @keyframes review-scroll {\n    from {\n      transform: translateX(0);\n    }\n    to {\n      transform: translateX(var(--scroll-end, -100%));\n    }\n  }\n  \n  .review-carousel-section {\n    width: 100%;\n    padding: 80px 0;\n    overflow: hidden;\n    position: relative;\n    background-color: #07080b;\n  }\n\n  .review-carousel-container {\n    width: 100%;\n    overflow: hidden;\n    position: relative;\n    cursor: grab;\n  }\n\n  .review-carousel-container:active {\n    cursor: grabbing;\n  }\n\n  .review-carousel-track {\n    display: flex;\n    animation: review-scroll var(--carousel-speed) linear forwards;\n    user-select: none;\n    will-change: transform;\n  }\n\n  .review-carousel-container.scrolling .review-carousel-track {\n    animation-play-state: paused;\n  }\n\n  .review-carousel-container.scrolling {\n    cursor: grabbing;\n  }\n\n  .review-carousel-track.manual-scroll {\n    animation: none !important;\n  }\n\n  .review-carousel-track .review-item {\n    margin-right: 30px;\n  }\n\n  .review-item {\n    flex: 0 0 380px;\n    min-width: 380px;\n    flex-shrink: 0;\n  }\n\n  .review-box {\n    background-color: #1a1b1f;\n    border: 1px solid #2a2b2f;\n    border-radius: 16px;\n    padding: 32px;\n    height: 100%;\n    display: flex;\n    flex-direction: column;\n    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);\n    transition: transform 0.3s ease, box-shadow 0.3s ease;\n  }\n\n  .review-box:hover {\n    transform: translateY(-5px);\n    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.4);\n  }\n\n  .review-stars {\n    color: #ffd700;\n    font-size: 20px;\n    margin-bottom: 16px;\n    letter-spacing: 2px;\n  }\n\n  .review-text {\n    color: #e0e0e0;\n    font-size: 16px;\n    line-height: 1.6;\n    margin: 0 0 24px 0;\n    flex-grow: 1;\n    font-style: italic;\n  }\n\n  .review-author {\n    display: flex;\n    flex-direction: column;\n    margin-top: auto;\n  }\n\n  .review-author strong {\n    color: #ffffff;\n    font-size: 16px;\n    font-weight: 600;\n    margin-bottom: 4px;\n  }\n\n  .review-author span {\n    color: #a0a0a0;\n    font-size: 14px;\n  }\n\n  .review-carousel-section:hover .review-carousel-track {\n    animation-play-state: paused;\n  }\n\n  @media (max-width: 768px) {\n    .review-item {\n      flex: 0 0 320px;\n      min-width: 320px;\n    }\n\n    .review-box {\n      padding: 24px;\n    }\n\n    .review-carousel-section {\n      padding: 60px 0;\n    }\n  }\n\n  @media (max-width: 480px) {\n    .review-item {\n      flex: 0 0 280px;\n      min-width: 280px;\n    }\n\n    .review-text {\n      font-size: 14px;\n    }\n  }\n</style>\n\n<div class=\"review-carousel-section\" style=\"background-color: #07080b;\">\n  <div class=\"review-carousel-container\">\n    <div class=\"review-carousel-track\">\n      {% comment %} First set of reviews {% endcomment %}\n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"UNNAP forces me to actually get out of bed. No more hitting snooze - I have to physically get up and scan it. Life changer for my morning routine!\"</p>\n          <div class=\"review-author\">\n            <strong>Sarah Mitchell</strong>\n            <span>Fitness Coach</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"I used to sleep through multiple alarms. Now I have to get up and walk to my UNNAP device to turn it off. It's the accountability I needed!\"</p>\n          <div class=\"review-author\">\n            <strong>James Rodriguez</strong>\n            <span>Software Engineer</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"Perfect for medication reminders! I place UNNAP next to my pills, so when the alarm goes off, I'm already there to take them. No more forgetting!\"</p>\n          <div class=\"review-author\">\n            <strong>Emily Chen</strong>\n            <span>Marketing Director</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"The physical requirement to scan the device is genius. Once I'm up and moving, I stay up. No more falling back into bed!\"</p>\n          <div class=\"review-author\">\n            <strong>Michael Thompson</strong>\n            <span>Entrepreneur</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"I struggle with depression and getting out of bed. UNNAP gives me that push I need - I can't ignore it, I have to get up and move.\"</p>\n          <div class=\"review-author\">\n            <strong>Jessica Williams</strong>\n            <span>Yoga Instructor</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"As a doctor, I recommend UNNAP to patients who need medication reminders. The scan requirement ensures they actually go to where their meds are.\"</p>\n          <div class=\"review-author\">\n            <strong>David Park</strong>\n            <span>Doctor</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"I was skeptical, but having to physically scan UNNAP to turn it off has transformed my mornings. I'm actually productive before 9am now!\"</p>\n          <div class=\"review-author\">\n            <strong>Amanda Foster</strong>\n            <span>Teacher</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"My partner and I both use UNNAP. We place it in the kitchen, so by the time we scan it, we're already making coffee and starting our day together.\"</p>\n          <div class=\"review-author\">\n            <strong>Robert Martinez</strong>\n            <span>Architect</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"Night shift worker here. UNNAP helps me wake up at the right time and actually get moving. The scan requirement means I can't just roll over and go back to sleep.\"</p>\n          <div class=\"review-author\">\n            <strong>Lisa Anderson</strong>\n            <span>Nurse</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"I've tried every alarm app and gadget. UNNAP is the only one that works because you can't cheat it - you MUST get up and scan. Game changer!\"</p>\n          <div class=\"review-author\">\n            <strong>Christopher Lee</strong>\n            <span>Consultant</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"UNNAP has helped me build a consistent morning routine. By forcing me to get up and move, I'm more motivated to start my day right. Highly recommend!\"</p>\n          <div class=\"review-author\">\n            <strong>Nicole Brown</strong>\n            <span>Designer</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"The physical act of scanning UNNAP breaks the cycle of hitting snooze. Once I'm up and moving, I stay up. It's become essential to my daily routine.\"</p>\n          <div class=\"review-author\">\n            <strong>Daniel Taylor</strong>\n            <span>Financial Analyst</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"I'm a chronic snoozer. UNNAP changed everything because I can't just reach over and turn it off - I have to get out of bed and walk to it. Brilliant design!\"</p>\n          <div class=\"review-author\">\n            <strong>Marcus Johnson</strong>\n            <span>Graphic Designer</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"UNNAP sits in my bathroom. By the time I scan it to turn off the alarm, I'm already there to brush my teeth and start my day. No more going back to bed!\"</p>\n          <div class=\"review-author\">\n            <strong>Rachel Green</strong>\n            <span>Nutritionist</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"As someone with ADHD, I need that physical push to get moving. UNNAP's scan requirement is exactly what I needed. I'm more consistent than ever!\"</p>\n          <div class=\"review-author\">\n            <strong>Alex Rivera</strong>\n            <span>Content Creator</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"I place UNNAP by my workout gear. When the alarm goes off, I'm already there and ready to exercise. It's eliminated my excuses completely!\"</p>\n          <div class=\"review-author\">\n            <strong>Jordan Kim</strong>\n            <span>Personal Trainer</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"College student here. UNNAP helps me wake up for early classes. The scan requirement means I can't just turn it off and go back to sleep. Game changer!\"</p>\n          <div class=\"review-author\">\n            <strong>Taylor Morgan</strong>\n            <span>Student</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"I use UNNAP for my morning vitamins. Placed it right next to my supplement organizer. Now I never forget because I have to go there to turn it off!\"</p>\n          <div class=\"review-author\">\n            <strong>Casey White</strong>\n            <span>Project Manager</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"The best part about UNNAP? You can't cheat it. No app to close, no button to press from bed. You MUST physically get up. That's what makes it work!\"</p>\n          <div class=\"review-author\">\n            <strong>Morgan Davis</strong>\n            <span>Photographer</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"I'm a new parent and sleep is precious. UNNAP ensures I actually wake up when I need to, not just hit snooze and miss important moments with my baby.\"</p>\n          <div class=\"review-author\">\n            <strong>Sam Wilson</strong>\n            <span>Parent</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"UNNAP helped me break my phone alarm dependency. Now I have a dedicated device that forces me to get up. My mornings are so much better!\"</p>\n          <div class=\"review-author\">\n            <strong>Riley Martinez</strong>\n            <span>Writer</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"I set UNNAP in my kitchen for morning alarms. By the time I scan it, I'm already making breakfast and starting my day. No more skipping meals!\"</p>\n          <div class=\"review-author\">\n            <strong>Quinn Anderson</strong>\n            <span>Chef</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"Chronic fatigue sufferer here. UNNAP gives me that extra push I need. Once I'm up and moving to scan it, I'm already past the hardest part of waking up.\"</p>\n          <div class=\"review-author\">\n            <strong>Blake Thompson</strong>\n            <span>Retail Manager</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"I use UNNAP for my diabetes medication. Placed it right where I keep my insulin. The scan requirement ensures I never miss a dose. Life-saving device!\"</p>\n          <div class=\"review-author\">\n            <strong>Avery Chen</strong>\n            <span>Accountant</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"Remote worker struggling with morning motivation. UNNAP forces me out of bed and to my desk. By the time I scan it, I'm ready to start working!\"</p>\n          <div class=\"review-author\">\n            <strong>Skylar Lee</strong>\n            <span>Freelancer</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"UNNAP is perfect for my meditation practice. I place it in my meditation corner, so when I scan it, I'm already there to start my morning mindfulness routine.\"</p>\n          <div class=\"review-author\">\n            <strong>River Patel</strong>\n            <span>Life Coach</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"I'm a shift worker with irregular sleep. UNNAP helps me wake up at different times without falling back asleep. The physical requirement is key!\"</p>\n          <div class=\"review-author\">\n            <strong>Phoenix Brown</strong>\n            <span>Security Guard</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"UNNAP sits by my water bottle. When I scan it in the morning, I'm already there to hydrate. It's helped me build better morning habits!\"</p>\n          <div class=\"review-author\">\n            <strong>Sage Williams</strong>\n            <span>Hydration Coach</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"I've tried everything to wake up on time. UNNAP is the only solution that works because you physically cannot ignore it. Worth every penny!\"</p>\n          <div class=\"review-author\">\n            <strong>Rowan Garcia</strong>\n            <span>Sales Rep</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"UNNAP helped me establish a consistent sleep schedule. By forcing me to get up at the same time every day, my body clock has reset completely.\"</p>\n          <div class=\"review-author\">\n            <strong>Indigo Taylor</strong>\n            <span>Sleep Therapist</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"I place UNNAP by my coffee maker. When the alarm goes off, I'm already in the kitchen making my morning brew. Best way to start the day!\"</p>\n          <div class=\"review-author\">\n            <strong>Ocean Martinez</strong>\n            <span>Barista</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"As someone recovering from surgery, UNNAP ensures I take my pain medication on time. The scan requirement means I actually get up and move, which helps recovery!\"</p>\n          <div class=\"review-author\">\n            <strong>Kai Rodriguez</strong>\n            <span>Physical Therapist</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"UNNAP is brilliant for my morning skincare routine. I place it by my bathroom sink, so when I scan it, I'm already there to wash my face and start my day right!\"</p>\n          <div class=\"review-author\">\n            <strong>Luna Foster</strong>\n            <span>Beauty Blogger</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"I'm a heavy sleeper who sleeps through everything. UNNAP's persistent alarm and scan requirement is the only thing that actually wakes me up. Thank you!\"</p>\n          <div class=\"review-author\">\n            <strong>Atlas Moore</strong>\n            <span>Construction Worker</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"UNNAP helps me with my morning journaling habit. I place it on my desk, so when I scan it, I'm already there to write. It's built consistency I never had!\"</p>\n          <div class=\"review-author\">\n            <strong>Nova Jackson</strong>\n            <span>Journalist</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"I use UNNAP for my blood pressure medication. Placed it right next to my pill organizer. The scan requirement ensures I never miss a dose. My doctor is impressed!\"</p>\n          <div class=\"review-author\">\n            <strong>Zephyr Lewis</strong>\n            <span>Retired Teacher</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"UNNAP sits by my front door for morning walks. When I scan it, I'm already there with my shoes on. It's helped me build a daily walking habit!\"</p>\n          <div class=\"review-author\">\n            <strong>Orion Walker</strong>\n            <span>Retiree</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"I'm a night owl trying to become a morning person. UNNAP forces me to get up and move, which helps reset my circadian rhythm. It's working!\"</p>\n          <div class=\"review-author\">\n            <strong>Juno Hall</strong>\n            <span>Musician</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"UNNAP is perfect for my morning reading habit. I place it by my reading chair, so when I scan it, I'm already there with my book. Best way to start the day!\"</p>\n          <div class=\"review-author\">\n            <strong>Cosmos Young</strong>\n            <span>Librarian</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"I use UNNAP for my morning stretching routine. Placed it in my workout space, so when I scan it, I'm already there to stretch. It's eliminated my excuses!\"</p>\n          <div class=\"review-author\">\n            <strong>Nova King</strong>\n            <span>Yoga Instructor</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"UNNAP helped me break my phone addiction in the morning. Instead of scrolling in bed, I have to get up and scan the device. My productivity has skyrocketed!\"</p>\n          <div class=\"review-author\">\n            <strong>Atlas Wright</strong>\n            <span>Productivity Coach</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"review-item\">\n        <div class=\"review-box\">\n          <div class=\"review-stars\">★★★★★</div>\n          <p class=\"review-text\">\"I place UNNAP by my plant care station. When I scan it in the morning, I'm already there to water my plants. It's helped me keep them alive!\"</p>\n          <div class=\"review-author\">\n            <strong>Luna Scott</strong>\n            <span>Gardener</span>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n  (function() {\n    const container = document.querySelector('.review-carousel-container');\n    const track = document.querySelector('.review-carousel-track');\n    \n    if (!container || !track) return;\n    \n    // Calculate and set the animation end position\n    const trackWidth = track.scrollWidth;\n    const containerWidth = container.offsetWidth;\n    const maxScroll = -(trackWidth - containerWidth);\n    track.style.setProperty('--scroll-end', maxScroll + 'px');\n    \n    let isDown = false;\n    let startX;\n    let currentTranslate = 0;\n    let animationId;\n    let scrollTimeout;\n    let isManualScrolling = false;\n    \n    // Mouse drag functionality\n    container.addEventListener('mousedown', (e) => {\n      isDown = true;\n      isManualScrolling = true;\n      track.classList.add('manual-scroll');\n      container.classList.add('scrolling');\n      startX = e.pageX;\n      container.style.cursor = 'grabbing';\n      \n      // Get current transform value\n      const style = window.getComputedStyle(track);\n      const matrix = new DOMMatrix(style.transform);\n      currentTranslate = matrix.m41;\n    });\n    \n    container.addEventListener('mouseleave', () => {\n      if (isDown) {\n        isDown = false;\n        container.style.cursor = 'grab';\n      }\n    });\n    \n    container.addEventListener('mouseup', () => {\n      if (isDown) {\n        isDown = false;\n        container.style.cursor = 'grab';\n        resetAnimation();\n      }\n    });\n    \n    container.addEventListener('mousemove', (e) => {\n      if (!isDown) return;\n      e.preventDefault();\n      const x = e.pageX;\n      // Use 1:1 movement - scroll moves exactly as fast as mouse moves\n      const walk = x - startX;\n      currentTranslate = currentTranslate + walk;\n      \n      // Constrain to bounds (0 to maxScroll)\n      if (currentTranslate > 0) {\n        currentTranslate = 0;\n      } else if (currentTranslate < maxScroll) {\n        currentTranslate = maxScroll;\n      }\n      \n      track.style.transform = `translateX(${currentTranslate}px)`;\n      startX = x;\n    });\n    \n    // Touch/swipe functionality\n    let touchStartX = 0;\n    let touchCurrentTranslate = 0;\n    \n    container.addEventListener('touchstart', (e) => {\n      isManualScrolling = true;\n      track.classList.add('manual-scroll');\n      container.classList.add('scrolling');\n      touchStartX = e.touches[0].pageX;\n      \n      const style = window.getComputedStyle(track);\n      const matrix = new DOMMatrix(style.transform);\n      touchCurrentTranslate = matrix.m41;\n    });\n    \n    container.addEventListener('touchmove', (e) => {\n      e.preventDefault();\n      const x = e.touches[0].pageX;\n      // Use 1:1 movement - scroll moves exactly as fast as finger moves\n      const walk = x - touchStartX;\n      touchCurrentTranslate = touchCurrentTranslate + walk;\n      \n      // Constrain to bounds (0 to maxScroll)\n      if (touchCurrentTranslate > 0) {\n        touchCurrentTranslate = 0;\n      } else if (touchCurrentTranslate < maxScroll) {\n        touchCurrentTranslate = maxScroll;\n      }\n      \n      track.style.transform = `translateX(${touchCurrentTranslate}px)`;\n      touchStartX = x;\n    });\n    \n    container.addEventListener('touchend', () => {\n      currentTranslate = touchCurrentTranslate;\n      resetAnimation();\n    });\n    \n    // Wheel scroll functionality\n    container.addEventListener('wheel', (e) => {\n      e.preventDefault();\n      isManualScrolling = true;\n      track.classList.add('manual-scroll');\n      container.classList.add('scrolling');\n      \n      const style = window.getComputedStyle(track);\n      const matrix = new DOMMatrix(style.transform);\n      currentTranslate = matrix.m41;\n      currentTranslate += e.deltaY;\n      \n      // Constrain to bounds (0 to maxScroll)\n      if (currentTranslate > 0) {\n        currentTranslate = 0;\n      } else if (currentTranslate < maxScroll) {\n        currentTranslate = maxScroll;\n      }\n      \n      track.style.transform = `translateX(${currentTranslate}px)`;\n      resetAnimation();\n    });\n    \n    // Reset animation after user stops interacting\n    function resetAnimation() {\n      clearTimeout(scrollTimeout);\n      scrollTimeout = setTimeout(() => {\n        isManualScrolling = false;\n        // Remove inline transform to let CSS animation take over\n        track.style.transform = '';\n        // Remove manual-scroll class to let CSS animation resume\n        track.classList.remove('manual-scroll');\n        container.classList.remove('scrolling');\n        // CSS animation will continue from where it left off or restart\n      }, 2000);\n    }\n    \n    // Pause on hover\n    container.addEventListener('mouseenter', () => {\n      if (!isManualScrolling) {\n        container.classList.add('scrolling');\n      }\n    });\n    \n    container.addEventListener('mouseleave', () => {\n      if (!isDown && !isManualScrolling) {\n        container.classList.remove('scrolling');\n      }\n    });\n  })();\n</script>",
