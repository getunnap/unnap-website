            "accordion_row_RCzbPe": {
              "type": "_accordion-row",
              "name": "t:names.accordion_dash_row",
              "settings": {
                "heading": "How is UNNAP different from a regular alarm app?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_V4YHV3": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>UNNAP blends <strong>physical action</strong> with smart alarm design. You can’t just swipe to snooze — you have to get up and tap your phone to the UNNAP device. This breaks the snooze habit and helps you own your mornings.</p>",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
                    "type_preset": "rte",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
