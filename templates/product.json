            },
            "accordion_row_hmrtLx": {
              "type": "_accordion-row",
              "name": "t:names.accordion_dash_row",
              "settings": {
                "heading": "What do I get with UNNAP Pro?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_KcUjLp": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>UNNAP Pro gives you the full experience — everything designed to keep you accountable, motivated, and even competitive:</p><ul><li><strong>Custom alarm sounds</strong> <br/></li><li><strong>Friends page</strong> — see your friends’ streaks and support each other.<br/></li><li><strong>Groups & leaderboards</strong> — create groups with friends, family, or housemates and compete for the top spot.</li><li><strong>My Data </strong>— Track your wake-up times, consistency, and streak milestones to see your progress over time.</li></ul>",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
                    "type_preset": "rte",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
