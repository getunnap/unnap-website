                "heading": "Is UNNAP compatible with my phone?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_jGEAPt": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>At launch, UNNAP is available <strong>exclusively for iOS</strong>. We plan to bring Android support in the future, but it’s not available yet.</p>",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
