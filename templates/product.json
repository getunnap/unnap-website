                    "corner_radius": 0,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "text_KcUjLp"
              ]
            },
            "accordion_row_8rNbXe": {
              "type": "_accordion-row",
